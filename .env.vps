# Odys VPS Deployment — copy to .env on VPS
# Usage: cp .env.vps .env && docker compose up -d

# ============================================================
# Network
# ============================================================
# Bind to all interfaces for VPS (NOT localhost)
APP_BIND=0.0.0.0
APP_PORT=7000

# ============================================================
# Auth
# ============================================================
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=CHANGE_ME_ON_VPS

# ============================================================
# LLM — point to your local Ollama on VPS
# ============================================================
LLM_HOST=host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ============================================================
# Embeddings — use local FastEmbed (ONNX, no API key needed)
# ============================================================
EMBEDDING_URL=
EMBEDDING_MODEL=

# ============================================================
# Database
# ============================================================
# SQLite (default) — fine for single user
DATABASE_URL=sqlite:///./data/app.db

# ============================================================
# Services
# ============================================================
ODYSSEUS_INPROCESS_POLLERS=1
ODYSSEUS_INPROCESS_TASKS=1
ODYSSEUS_SCRIPT_HOST=localhost

# ============================================================
# Data persistence
# ============================================================
APP_DATA_DIR=./data
APP_LOGS_DIR=./logs

# ============================================================
# Upload limits (50MB default)
# ============================================================
ODYSSEUS_CHAT_UPLOAD_MAX_BYTES=52428800

# ============================================================
# Security
# ============================================================
# If behind nginx reverse proxy with HTTPS:
# SECURE_COOKIES=true
# ALLOWED_ORIGINS=https://odys.yourdomain.com

# If direct VPS access (no HTTPS):
SECURE_COOKIES=false
ALLOWED_ORIGINS=http://your-vps-ip:7000
